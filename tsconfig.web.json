{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.web.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src/renderer/**/*",
    "src/engine/types.ts",
    "src/engine/srs.ts",
    "src/engine/srs-core.ts",
    "src/engine/srs-sm2.ts",
    "src/engine/srs-fsrs.ts",
    "src/engine/write.ts"
  ]
}
