{
  "name": "study-engine",
  "version": "0.1.0",
  "description": "Spaced-repetition study app (SM-2) — Electron + React + TS. Drives the private study-log. AWS / English / any domain.",
  "author": "akira-toriyama",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "node scripts/fix-electron.mjs",
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "preview": "ELECTRON_RUN_AS_NODE= electron-vite preview",
    "start": "ELECTRON_RUN_AS_NODE= electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "smoke": "tsx src/engine/smoke.ts",
    "check-bundle": "node scripts/check-bundle.mjs",
    "rebuild-state": "tsx scripts/rebuild-state.ts",
    "test:speak": "electron-vite build && node scripts/test-speak.mjs",
    "dist": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ts-fsrs": "5.4.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "playwright-core": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
