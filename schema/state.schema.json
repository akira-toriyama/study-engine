{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "srs/state.json",
  "description": "Global SM-2 state, keyed by question id. Rebuildable from reviews.jsonl.",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "required": ["interval", "ease", "due", "reps", "lapses"],
    "properties": {
      "interval": { "type": "integer", "minimum": 0, "description": "days until next review" },
      "ease": { "type": "number", "minimum": 1.3, "description": "ease factor (>= 1.3)" },
      "due": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "reps": { "type": "integer", "minimum": 0 },
      "lapses": { "type": "integer", "minimum": 0 },
      "last_review": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "last_grade": { "type": "integer", "minimum": 1, "maximum": 4 }
    },
    "additionalProperties": false
  }
}
